# ── Configuration SNICV — copiez ce fichier en .env et adaptez les valeurs ──

# Sécurité Django
SECRET_KEY=changez-moi-en-production-avec-une-cle-longue-et-aleatoire
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Base de données
# En dev, laissez vide pour utiliser SQLite automatiquement.
# En prod (PostgreSQL) :
# DATABASE_URL=postgres://user:password@localhost:5432/snicv
DATABASE_URL=

# CORS (front React)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# HTTPS : mettre à True en production (redirige tout le trafic vers HTTPS)
SECURE_SSL_REDIRECT=False

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Envoi OTP (vérification compte)
# Backends disponibles : console (dev), mock (tests). Un vrai fournisseur sera branché plus tard.
OTP_BACKEND=console
OTP_CODE_TTL_MINUTES=10
OTP_CODE_LENGTH=6

# Immatriculation (suffixe bureau émetteur, ex. « AB 4821 BS »)
IMMATRICULATION_SUFFIXE=BS

# Certificat QR — clés RSA du SNICV (générées via: python manage.py generer_cles_snicv)
# NE JAMAIS committer la clé privée. En production : secret manager.
SNICV_PRIVATE_KEY_PATH=
SNICV_PUBLIC_KEY_PATH=
# En production (Railway) : clés PEM en base64 (prioritaires sur les chemins ci-dessus).
# Obtenez-les via : python manage.py generer_cles_snicv --b64
SNICV_PRIVATE_KEY_B64=
SNICV_PUBLIC_KEY_B64=
# URL de base encodée dans le QR (vers l'endpoint de vérification)
SNICV_VERIFY_BASE_URL=http://localhost:8000/api/v1
# Durée de validité du certificat (années)
CERTIFICAT_VALIDITE_ANNEES=1
